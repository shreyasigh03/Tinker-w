

# ── Supabase (Dashboard → Project Settings → API) ──
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (secret), NOT the anon key. Server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (resend.com → API Keys) ──
RESEND_API_KEY=re_your_api_key
# Must be an address on a domain you've verified in Resend:
FROM_EMAIL=Tinker <hello@tinkerdesktop.com>

# ── CORS: your live site origin (or "*" while testing) ──
ALLOWED_ORIGIN=https://tinkerdesktop.com
